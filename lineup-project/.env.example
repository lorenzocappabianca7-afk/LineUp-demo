# Copia in .env e compila i valori (non committare .env)
NODE_ENV=production

# Obbligatorio — Neon o Supabase (PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Obbligatorio per ricerca luoghi nel wizard demo
OPENAI_API_KEY=sk-...

# Opzionale — feedback demo via email (altrimenti solo ai_log.txt)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tua@gmail.com
SMTP_PASS=password-app-gmail
SMTP_FROM=LineUp Demo <tua@gmail.com>
PIANIFICA_DEMO_FEEDBACK_TO=lorenzo.cappabianca7@gmail.com

# Solo in locale
# PORT=5174
