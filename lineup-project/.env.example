# Copia in .env e compila i valori (non committare .env)
NODE_ENV=production

# Obbligatorio — Neon o Supabase (PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Obbligatorio per ricerca luoghi nel wizard demo
OPENAI_API_KEY=sk-...

# Email feedback demo — su Render FREE usa Resend (SMTP Gmail va in timeout)
RESEND_API_KEY=re_...
RESEND_FROM=LineUp <lineuplf@gmail.com>

# SMTP Gmail: ok in locale o Render a pagamento; bloccato su Render free (porte 587/465)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=lineuplf@gmail.com
SMTP_PASS=password-app-gmail
SMTP_FROM=LineUp <lineuplf@gmail.com>
PIANIFICA_DEMO_FEEDBACK_TO=lineuplf@gmail.com

# Solo in locale
# PORT=5174
